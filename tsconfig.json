{
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "paths": {
      "@/*": ["src/*"],
      "vue": ["node_modules/vue/dist/vue.d.ts"],
      "@vue/runtime-core": ["node_modules/.pnpm/@vue+runtime-dom@3.5.33/node_modules/@vue/runtime-core/dist/runtime-core.d.ts"],
      "@vue/runtime-dom": ["node_modules/.pnpm/@vue+runtime-dom@3.5.33/node_modules/@vue/runtime-dom/dist/runtime-dom.d.ts"],
      "@vue/reactivity": ["node_modules/.pnpm/@vue+runtime-dom@3.5.33/node_modules/@vue/reactivity/dist/reactivity.d.ts"],
      "@vue/shared": ["node_modules/.pnpm/@vue+runtime-dom@3.5.33/node_modules/@vue/shared/dist/shared.d.ts"]
    },
    "types": ["vite/client", "element-plus/global", "vue"],
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "mock/**/*.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
